rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HIPAA §164.312(a)(1): Access Control ──────────────────────────────
    // Principle of Least Privilege: users access ONLY their own data.
    // No wildcard reads or writes are permitted anywhere.

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Validate that a write contains the expected userId field
    function isValidWrite(userId) {
      return isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.auth.uid == userId;
    }

    // ── User Profiles (PHI: health data, dosha, vitals) ───────────────────
    match /users/{userId} {
      allow read:   if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if false; // HIPAA: retain records — soft-delete only
    }

    // ── Appointments (PHI: doctor notes, diagnoses) ───────────────────────
    match /appointments/{appointmentId} {
      allow read:   if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if false; // HIPAA: medical records must be retained
    }

    // ── Shop Orders (financial records) ───────────────────────────────────
    match /orders/{orderId} {
      allow read:   if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ── Heart Rate Logs (PHI: biometric data) ─────────────────────────────
    match /heart_logs/{logId} {
      allow read:   if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if false; // Immutable biometric records
      allow delete: if false;
    }

    // ── Health Analyses / AI Reports (PHI: diagnosis, symptoms) ──────────
    match /health_analyses/{analysisId} {
      allow read:   if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if false; // AI reports are immutable once created
      allow delete: if false;
    }

    // ── HIPAA Audit Logs (WRITE-ONLY — §164.312(b) Audit Controls) ───────
    // Users can create audit entries but NEVER read, update, or delete them.
    // Only Firebase Admin SDK / Cloud Functions may read audit logs.
    match /audit_logs/{logId} {
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.hipaaCompliant == true;
      allow read:   if false; // Admin-only via Firebase Admin SDK
      allow update: if false;
      allow delete: if false;
    }

    // ── Default Deny — block all other collections ────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
